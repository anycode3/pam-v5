(export (version "E")
  (design
    (source "/pam/dual_pi/dual_pi.kicad_sch")
    (date "2026-05-18")
    (tool "KiCad 8.0")
  )
  (components
    (comp (ref "TL1")
      (value "50Ohm/800um")
      (footprint "RF:Microstrip")
      (libsource (lib "RF") (part "TL_MICROSTRIP") (description "Microstrip Transmission Line"))
    )
    (comp (ref "C1")
      (value "1.5pF")
      (footprint "RF:MIM_Cap")
      (libsource (lib "RF") (part "CAP_MIM") (description "MIM Capacitor"))
    )
    (comp (ref "L1")
      (value "3nH")
      (footprint "RF:Spiral_Ind")
      (libsource (lib "RF") (part "IND_SPIRAL") (description "Spiral Inductor"))
    )
    (comp (ref "C2")
      (value "1.5pF")
      (footprint "RF:MIM_Cap")
      (libsource (lib "RF") (part "CAP_MIM") (description "MIM Capacitor"))
    )
    (comp (ref "TL2")
      (value "50Ohm/1500um")
      (footprint "RF:Microstrip")
      (libsource (lib "RF") (part "TL_MICROSTRIP") (description "Microstrip Transmission Line"))
    )
    (comp (ref "C3")
      (value "2pF")
      (footprint "RF:MIM_Cap")
      (libsource (lib "RF") (part "CAP_MIM") (description "MIM Capacitor"))
    )
    (comp (ref "L2")
      (value "3.5nH")
      (footprint "RF:Spiral_Ind")
      (libsource (lib "RF") (part "IND_SPIRAL") (description "Spiral Inductor"))
    )
    (comp (ref "C4")
      (value "2pF")
      (footprint "RF:MIM_Cap")
      (libsource (lib "RF") (part "CAP_MIM") (description "MIM Capacitor"))
    )
    (comp (ref "TL3")
      (value "50Ohm/800um")
      (footprint "RF:Microstrip")
      (libsource (lib "RF") (part "TL_MICROSTRIP") (description "Microstrip Transmission Line"))
    )
  )
  (nets
    (net (code 1) (name "RFIN")
      (node (ref "TL1") (pin "P1"))
    )
    (net (code 2) (name "NET_TL1_C1_L1")
      (node (ref "TL1") (pin "P2"))
      (node (ref "C1") (pin "PI"))
      (node (ref "L1") (pin "P1"))
    )
    (net (code 3) (name "GND1")
      (node (ref "C1") (pin "NIN"))
    )
    (net (code 4) (name "NET_L1_C2_TL2")
      (node (ref "L1") (pin "P2"))
      (node (ref "C2") (pin "PI"))
      (node (ref "TL2") (pin "P1"))
    )
    (net (code 5) (name "GND2")
      (node (ref "C2") (pin "NIN"))
    )
    (net (code 6) (name "NET_TL2_C3_L2")
      (node (ref "TL2") (pin "P2"))
      (node (ref "C3") (pin "PI"))
      (node (ref "L2") (pin "P1"))
    )
    (net (code 7) (name "GND3")
      (node (ref "C3") (pin "NIN"))
    )
    (net (code 8) (name "NET_L2_C4_TL3")
      (node (ref "L2") (pin "P2"))
      (node (ref "C4") (pin "PI"))
      (node (ref "TL3") (pin "P1"))
    )
    (net (code 9) (name "GND4")
      (node (ref "C4") (pin "NIN"))
    )
    (net (code 10) (name "RFOUT")
      (node (ref "TL3") (pin "P2"))
    )
  )
)
